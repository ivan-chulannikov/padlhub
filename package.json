{
  "name": "padlhub-trial-schedule",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "npm --prefix backend run start:dev",
    "build": "tsc -b && vite build",
    "build:api": "npm --prefix backend run build",
    "lint": "oxlint",
    "check:fsd": "node scripts/check-fsd-imports.mjs",
    "lint:api": "npm --prefix backend run lint",
    "test:api": "npm --prefix backend test -- --runInBand",
    "check": "npm run check:fsd && npm run lint && npm run build && npm run lint:api && npm run build:api && npm run test:api",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
